<devices>
	<device id="1">
		<name>Calefacció</name>
		<description>Càrrega calefacció</description>
		<historify active="0" period="1"></historify> <!-- period as seconds -->
		<fire active="1" period="12"> <!-- period as hours -->
			<!-- Start the device at a specified date or time period -->
			<date>
				<!-- Each entry can be formatted as: dd, dd/mm, dd/mm/yyyy -->
				<!-- The period attribute sets the hourly interval -->
				<!-- The duration attribute sets the amount of hours the relay will be on -->
				<!-- The start attribute sets the time of day (24h format) at which the relay will start -->
				<!-- Multiple entries can be used, the system must use the one that bests matches the entry value -->
				<entry period="24" duration="5" start="00">01/01</entry>
				<entry period="48">01/06</entry>
			</date>
		</fire>

		<relay id_pin="RO2.1" pin="2.1"></relay>
		<digital_input id_pin="DI1.4" pin="1.4"></digital_input>
	</device>

	<device id="2">
		<name>Device 2</name>
		<description></description>
		<historify active="0" period="1"></historify> <!-- period as seconds -->
		<fire active="1" period="12"> <!-- period as hours -->
			<!-- Start the device at a specified date or time period -->
			<date>
				<entry period="24" duration="5" start="00">01/01</entry>
				<entry period="48">01/06</entry>
			</date>
		</fire>

		<relay id_pin="RO2.2" pin="2.2"></relay>
		<digital_input id_pin="DI1.2" pin="1.2"></digital_input>
	</device>

	<device id="3">
		<name>Device 3</name>
		<description></description>
		<historify active="0" period="1"></historify> <!-- period as seconds -->
		<fire active="1" period="12"> <!-- period as hours -->
			<!-- Start the device at a specified date or time period -->
			<date>
				<entry period="24" duration="5" start="00">01/01</entry>
				<entry period="48">01/06</entry>
			</date>
		</fire>

		<!-- In this case there is no relay associated with the device,
			 NO EMPTY ENTRY MUST BE PLACED -->
		<digital_input id_pin="DI2.1" pin="2.1"></digital_input>
	</device>
</devices>
